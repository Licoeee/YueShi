.custom-tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 98;
}

.custom-tab-bar__panel {
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: 40rpx;
  background: rgba(255, 250, 247, 0.95);
  box-shadow: 0 20rpx 36rpx -16rpx rgba(255, 124, 93, 0.34);
  backdrop-filter: blur(20rpx);
  overflow: hidden;
  --td-tab-bar-height: 118rpx;
  --td-font-body-large: 22rpx/30rpx "PingFang SC", "Microsoft YaHei", sans-serif;
  --td-font-body-extraSmall: 20rpx/28rpx "PingFang SC", "Microsoft YaHei", sans-serif;
}

.custom-tab-bar__item {
  min-width: 0;
  height: 118rpx;
  margin: 5rpx 0;
  padding: 0 6rpx;
}

.custom-tab-bar__item.t-tab-bar-item--crowded {
  padding: 0 2rpx;
}

.custom-tab-bar__item .t-tab-bar-item__content {
  border-radius: 20rpx;
}

.custom-tab-bar__item .t-tab-bar-item__text {
  min-width: 0;
  max-width: 100%;
}

.custom-tab-bar__item-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
  padding: 10rpx 0;
  border-radius: 18rpx;
  color: #a48d86;
  transition: background-color 120ms ease, color 120ms ease;
}

.custom-tab-bar__item-content--active {
  color: #e76545;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 237, 228, 0.96));
}

.custom-tab-bar__item-content--inactive {
  color: #a58e87;
}

.custom-tab-bar__icon-image {
  width: 36rpx;
  height: 36rpx;
}

.custom-tab-bar__label {
  display: block;
  max-width: 100%;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
  line-break: strict;
  text-align: center;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
  color: currentColor;
}
