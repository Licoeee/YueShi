<view class="customer-cart-scene">
  <view class="customer-cart-scene__hero">
    <text class="customer-cart-scene__title">购物车</text>
    <text class="customer-cart-scene__subtitle">当前已勾选 {{checkedCount}} 件蛋糕</text>
  </view>

  <view class="customer-cart-scene__empty" wx:if="{{items.length === 0}}">
    <t-empty description="暂无蛋糕，先去首页逛逛吧"></t-empty>
  </view>

  <view class="customer-cart-scene__list" wx:else>
    <t-swipe-cell
      wx:for="{{items}}"
      wx:key="id"
      right="{{deleteActions}}"
      data-item-id="{{item.id}}"
      bind:click="handleSwipeAction"
    >
      <view class="customer-cart-scene__item {{item.checked ? 'customer-cart-scene__item--checked' : ''}}">
        <view class="customer-cart-scene__select">
          <t-button
            t-class="customer-cart-scene__select-tag"
            size="small"
            theme="primary"
            variant="{{item.checked ? 'base' : 'outline'}}"
            data-item-id="{{item.id}}"
            bindtap="handleItemCheckChange"
          >{{item.checked ? '已选' : '未选'}}</t-button>
        </view>

        <t-image
          class="customer-cart-scene__cover"
          src="{{item.coverImageUrl}}"
          mode="aspectFill"
          shape="round"
          lazy="{{true}}"
        ></t-image>

        <view class="customer-cart-scene__meta">
          <text class="customer-cart-scene__name">{{item.productName}}</text>
          <text class="customer-cart-scene__spec">{{item.specLabel}}</text>
          <text class="customer-cart-scene__cream">{{item.creamLabel}}</text>
        </view>

        <view class="customer-cart-scene__price-stack">
          <text class="customer-cart-scene__price">¥ {{item.totalPrice}}</text>
          <text class="customer-cart-scene__quantity">x{{item.quantity}}</text>
        </view>
      </view>
    </t-swipe-cell>

    <view class="customer-cart-scene__summary">
      <view class="customer-cart-scene__summary-main">
        <t-button
          t-class="customer-cart-scene__toggle-all"
          size="small"
          theme="primary"
          variant="{{allChecked ? 'base' : 'outline'}}"
          bindtap="handleToggleAll"
        >{{allChecked ? '取消全选' : '全选'}}</t-button>

        <view class="customer-cart-scene__summary-copy">
          <view class="customer-cart-scene__summary-row">
            <text class="customer-cart-scene__summary-label">合计</text>
            <text class="customer-cart-scene__summary-price">¥ {{checkedAmount}}</text>
          </view>
          <text class="customer-cart-scene__summary-meta">已选 {{checkedCount}} 件蛋糕</text>
        </view>
      </view>

      <t-button
        t-class="customer-cart-scene__checkout-button"
        theme="primary"
        size="medium"
        disabled="{{!canCheckout}}"
        bindtap="handleCheckout"
      >去结算</t-button>
    </view>
  </view>
</view>
