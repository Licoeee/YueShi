.customer-cart-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-cart-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, 0.74);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(184, 111, 95, 0.12);
}

.customer-cart-scene__title {
  color: #553633;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-cart-scene__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.customer-cart-scene__empty {
  margin-top: 60rpx;
  padding: 40rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.customer-cart-scene__item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__item--checked {
  border-color: rgba(255, 145, 112, 0.7);
  background: linear-gradient(135deg, rgba(255, 245, 242, 0.98) 0%, rgba(255, 236, 228, 0.98) 100%);
  box-shadow: 0 20rpx 34rpx rgba(201, 103, 84, 0.18);
}

.customer-cart-scene__select {
  flex: none;
}

.customer-cart-scene__cover {
  width: 144rpx;
  height: 144rpx;
  flex: none;
  border-radius: 24rpx;
  background: rgba(255, 244, 240, 0.95);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.7);
}

.customer-cart-scene__meta {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 10rpx;
  color: #70514b;
  font-size: 22rpx;
  line-height: 1.5;
}

.customer-cart-scene__name {
  color: #553633;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.customer-cart-scene__spec {
  color: #7c5b55;
}

.customer-cart-scene__cream {
  color: #b06251;
  font-size: 22rpx;
  font-weight: 600;
}

.customer-cart-scene__price-stack {
  min-width: 120rpx;
  display: flex;
  flex: none;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.customer-cart-scene__price {
  color: #cc4f2f;
  font-size: 30rpx;
  font-weight: 700;
}

.customer-cart-scene__quantity {
  color: #7a5a54;
  font-size: 22rpx;
  font-weight: 600;
}

.customer-cart-scene__summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 8rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 30rpx rgba(188, 113, 96, 0.14);
}

.customer-cart-scene__summary-main {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.customer-cart-scene__summary-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.customer-cart-scene__summary-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  flex-wrap: nowrap;
}

.customer-cart-scene__summary-label {
  color: #7a5a54;
  font-size: 22rpx;
  font-weight: 600;
}

.customer-cart-scene__summary-price {
  color: #cc4f2f;
  font-size: 36rpx;
  font-weight: 700;
}

.customer-cart-scene__summary-meta {
  color: #8a6861;
  font-size: 22rpx;
  line-height: 1.4;
}

.customer-cart-scene__swipe-action {
  --td-swipe-cell-content-color: #ffffff;
}

.customer-cart-scene__toggle-all {
  --td-button-primary-outline-color: #cc5a3c;
  --td-button-primary-outline-border-color: rgba(229, 144, 117, 0.72);
  --td-button-primary-outline-bg-color: rgba(255, 247, 243, 0.96);
  --td-button-primary-color: #ffffff;
  --td-button-primary-bg-color: linear-gradient(135deg, #ff8a69 0%, #ffb07e 100%);
  --td-button-primary-border-color: rgba(255, 162, 133, 0.8);
}

.customer-cart-scene__select-tag {
  --td-button-primary-outline-color: #c85b3d;
  --td-button-primary-outline-border-color: rgba(229, 144, 117, 0.7);
  --td-button-primary-outline-bg-color: rgba(255, 248, 244, 0.98);
  --td-button-primary-color: #ffffff;
  --td-button-primary-bg-color: linear-gradient(135deg, #ff8a69 0%, #ffb07e 100%);
  --td-button-primary-border-color: rgba(255, 162, 133, 0.8);
}

.customer-cart-scene__checkout-button {
  --td-button-primary-bg-color: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  --td-button-primary-border-color: rgba(255, 170, 136, 0.75);
  min-width: 204rpx;
}
