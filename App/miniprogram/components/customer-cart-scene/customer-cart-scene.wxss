.customer-cart-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-cart-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, 0.74);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(184, 111, 95, 0.12);
}

.customer-cart-scene__title {
  color: #553633;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-cart-scene__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.customer-cart-scene__empty {
  margin-top: 60rpx;
  padding: 40rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.customer-cart-scene__item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__item--checked {
  border-color: rgba(255, 145, 112, 0.7);
  background: linear-gradient(135deg, rgba(255, 245, 242, 0.98) 0%, rgba(255, 236, 228, 0.98) 100%);
  box-shadow: 0 20rpx 34rpx rgba(201, 103, 84, 0.18);
}

.customer-cart-scene__select {
  flex: none;
}

.customer-cart-scene__select-pill {
  flex: none;
  min-width: 116rpx;
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.customer-cart-scene__select-pill--checked {
  color: #ffffff;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1px solid rgba(255, 170, 136, 0.82);
  box-shadow: 0 20rpx 36rpx rgba(243, 122, 87, 0.24);
}

.customer-cart-scene__select-pill--idle {
  color: #c85b3d;
  background: rgba(255, 248, 244, 0.98);
  border: 1px solid rgba(229, 144, 117, 0.72);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.68), 0 12rpx 28rpx rgba(204, 121, 92, 0.1);
}

.customer-cart-scene__cover {
  width: 124rpx;
  height: 124rpx;
  flex: none;
  border-radius: 24rpx;
  background: rgba(255, 244, 240, 0.95);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.7);
}

.customer-cart-scene__meta {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
  color: #70514b;
  font-size: 22rpx;
  line-height: 1.5;
}

.customer-cart-scene__name {
  color: #553633;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.customer-cart-scene__spec {
  color: #7c5b55;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.customer-cart-scene__cream {
  color: #b06251;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.customer-cart-scene__price-stack {
  min-width: 112rpx;
  display: flex;
  flex: none;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.customer-cart-scene__price {
  color: #cc4f2f;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.customer-cart-scene__quantity {
  color: #7a5a54;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.customer-cart-scene__summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 240rpx;
  align-items: center;
  column-gap: 24rpx;
  margin-top: 8rpx;
  padding: 32rpx 36rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 52rpx;
  border: 1px solid rgba(244, 210, 198, 0.92);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 36rpx 64rpx rgba(188, 113, 96, 0.14);
}

.customer-cart-scene__summary-main {
  min-width: 0;
  display: grid;
  grid-template-columns: 136rpx minmax(0, 1fr);
  align-items: center;
  column-gap: 20rpx;
}

.customer-cart-scene__summary-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.customer-cart-scene__summary-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  min-width: 0;
  white-space: nowrap;
}

.customer-cart-scene__summary-label {
  flex: none;
  color: #7a5a54;
  font-size: 24rpx;
  font-weight: 600;
}

.customer-cart-scene__summary-price {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  white-space: nowrap;
}

.customer-cart-scene__summary-price-currency {
  flex: none;
  color: #cc4f2f;
  font-size: 28rpx;
  font-weight: 700;
}

.customer-cart-scene__summary-price-value {
  min-width: 0;
  color: #cc4f2f;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  white-space: nowrap;
}

.customer-cart-scene__summary-price-value--tight {
  font-size: 34rpx;
}

.customer-cart-scene__summary-price-value--compact {
  font-size: 28rpx;
}

.customer-cart-scene__summary-meta {
  color: #8a6861;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.customer-cart-scene__swipe-delete {
  height: 100%;
  width: 184rpx;
  padding: 20rpx 20rpx 20rpx 0;
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
  box-sizing: border-box;
}

.customer-cart-scene__swipe-delete-button {
  width: 100%;
  border-radius: 40rpx;
  background: linear-gradient(160deg, #ff9b75 0%, #ff6f5d 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 32rpx 56rpx rgba(230, 108, 92, 0.28);
}

.customer-cart-scene__summary-toggle {
  min-height: 76rpx;
  padding: 0 32rpx;
  border-radius: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.01em;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.customer-cart-scene__summary-toggle--outline {
  color: #c85b3d;
  background: rgba(255, 247, 243, 0.98);
  border: 1rpx solid rgba(229, 144, 117, 0.74);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.65), 0 12rpx 28rpx rgba(204, 121, 92, 0.1);
}

.customer-cart-scene__summary-toggle--primary {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.customer-cart-scene__summary-cta {
  min-height: 76rpx;
  padding: 0 32rpx;
  border-radius: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.01em;
  white-space: nowrap;
  width: 100%;
  justify-self: end;
  box-sizing: border-box;
}

.customer-cart-scene__summary-cta--primary {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.customer-cart-scene__summary-cta--disabled {
  color: rgba(145, 116, 109, 0.82);
  background: rgba(244, 230, 226, 0.94);
  border: 1rpx solid rgba(221, 194, 186, 0.88);
  box-shadow: none;
}
