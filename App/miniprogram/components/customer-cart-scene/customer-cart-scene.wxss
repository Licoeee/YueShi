.customer-cart-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-cart-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, 0.74);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(184, 111, 95, 0.12);
}

.customer-cart-scene__title {
  color: #553633;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-cart-scene__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.customer-cart-scene__empty {
  margin-top: 60rpx;
  padding: 40rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.customer-cart-scene__item {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(188, 113, 96, 0.12);
}

.customer-cart-scene__meta {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #70514b;
  font-size: 22rpx;
  line-height: 1.5;
}

.customer-cart-scene__spec {
  flex: 1;
}

.customer-cart-scene__price {
  color: #cc4f2f;
  font-weight: 700;
}
