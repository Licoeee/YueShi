.customer-home-scene {
  position: relative;
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-home-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, 0.74);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(184, 111, 95, 0.12);
}

.customer-home-scene__brand {
  color: rgba(158, 70, 74, 0.92);
  font-family: YouYuan, FZYaoti, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.1;
  text-shadow: 0 10rpx 18rpx rgba(255, 136, 110, 0.18);
}

.customer-home-scene__subtitle {
  color: #6e4a44;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  line-height: 1.6;
}

.customer-home-scene__search {
  margin-top: 24rpx;
}

.customer-home-scene__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.customer-home-scene__filter {
  display: flex;
}

.customer-home-scene__waterfall {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-top: 24rpx;
}

.customer-home-scene__column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.customer-home-scene__card {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(245, 212, 203, 0.92);
  box-shadow: 0 18rpx 34rpx rgba(186, 112, 95, 0.15);
}

.customer-home-scene__image {
  display: block;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.customer-home-scene__card-body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 20rpx 24rpx;
}

.customer-home-scene__card-title {
  color: #563733;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.customer-home-scene__card-meta {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.customer-home-scene__card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-top: 4rpx;
}

.customer-home-scene__card-price {
  color: #cc4f2f;
  font-size: 30rpx;
  font-weight: 700;
}

.customer-home-scene__card-sales {
  color: #7c5a54;
  font-size: 22rpx;
  font-weight: 600;
}
