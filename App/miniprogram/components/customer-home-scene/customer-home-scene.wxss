.customer-home-scene {
  position: relative;
  min-height: 100%;
  padding: 12rpx 0 calc(172rpx + env(safe-area-inset-bottom));
}

.customer-home-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 2rpx;
}

.customer-home-scene__brand {
  color: rgba(180, 86, 94, 0.82);
  font-family: YouYuan, FZYaoti, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.1;
  text-shadow: 0 8rpx 22rpx rgba(255, 147, 127, 0.16);
}

.customer-home-scene__subtitle {
  color: #8c655f;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  line-height: 1.7;
}

.customer-home-scene__search {
  margin-top: 24rpx;
}

.customer-home-scene__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.customer-home-scene__filter {
  display: flex;
}

.customer-home-scene__waterfall {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-top: 24rpx;
}

.customer-home-scene__column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.customer-home-scene__card {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 20rpx 44rpx rgba(193, 116, 97, 0.1);
}

.customer-home-scene__image {
  display: block;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.customer-home-scene__card-body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 20rpx 24rpx;
}

.customer-home-scene__card-title {
  color: #68413d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.customer-home-scene__card-meta {
  color: #8c6b65;
  font-size: 22rpx;
  line-height: 1.7;
}

.customer-home-scene__card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-top: 4rpx;
}

.customer-home-scene__card-price {
  color: #e26b4b;
  font-size: 30rpx;
  font-weight: 700;
}

.customer-home-scene__card-sales {
  color: #9a746f;
  font-size: 22rpx;
}
