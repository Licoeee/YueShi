.customer-orders-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-orders-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 22rpx;
  border: 1px solid rgba(255, 255, 255, 0.74);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.78);
  box-shadow: 0 14rpx 32rpx rgba(184, 111, 95, 0.12);
}

.customer-orders-scene__title {
  color: #553633;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-orders-scene__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.customer-orders-scene__tabs-shell {
  margin-top: 24rpx;
  padding: 12rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.84);
  box-shadow: 0 14rpx 28rpx rgba(184, 111, 95, 0.1);
}

.customer-orders-scene__tab-list {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.customer-orders-scene__tab-item {
  display: flex;
  flex: 1;
  min-width: 0;
}

.customer-orders-scene__filter-tag {
  display: flex;
  width: 100%;
  justify-content: center;
}

.customer-orders-scene__tab-item .t-tag {
  width: 100%;
}

.customer-orders-scene__filter-tag .t-tag__text {
  flex: 1;
  text-align: center;
}

.customer-orders-scene__empty {
  margin-top: 60rpx;
  padding: 40rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.customer-orders-scene__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.customer-orders-scene__card {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(188, 113, 96, 0.12);
}

.customer-orders-scene__card--noted {
  border-color: rgba(247, 191, 201, 0.95);
  background: linear-gradient(180deg, rgba(255, 241, 244, 0.96) 0%, rgba(255, 252, 252, 0.96) 100%);
}

.customer-orders-scene__card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.customer-orders-scene__tag-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.customer-orders-scene__card-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.customer-orders-scene__order-id {
  color: #5b3a35;
  font-size: 24rpx;
  font-weight: 700;
}

.customer-orders-scene__item-summary {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.customer-orders-scene__meta-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.customer-orders-scene__meta-label {
  color: #8c6a63;
  font-size: 22rpx;
}

.customer-orders-scene__meta-value {
  color: #563733;
  font-size: 24rpx;
  font-weight: 600;
}
