.customer-product-detail {
  min-height: 100vh;
  padding: 40rpx 28rpx calc(200rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top left, rgba(255, 219, 210, 0.92), transparent 38%),
    linear-gradient(180deg, #fff8f4 0%, #fff3ef 44%, #fffdfb 100%);
  box-sizing: border-box;
}

.customer-product-detail__hero {
  overflow: hidden;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 22rpx 60rpx rgba(204, 128, 103, 0.16);
}

.customer-product-detail__hero-image {
  overflow: hidden;
}

.customer-product-detail__cover {
  width: 100%;
  height: 560rpx;
}

.customer-product-detail__hero-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
}

.customer-product-detail__eyebrow {
  font-size: 22rpx;
  line-height: 1.2;
  letter-spacing: 6rpx;
  color: #d08d78;
  text-transform: uppercase;
}

.customer-product-detail__title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #4c352d;
}

.customer-product-detail__description {
  font-size: 26rpx;
  line-height: 1.7;
  color: #7a5a50;
}

.customer-product-detail__price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.customer-product-detail__price {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 700;
  color: #d75d3f;
}

.customer-product-detail__section {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 48rpx rgba(210, 143, 120, 0.11);
}

.customer-product-detail__section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #543c34;
}

.customer-product-detail__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.customer-product-detail__chip {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 180rpx;
  padding: 18rpx 18rpx 16rpx;
  border: 2rpx solid rgba(225, 198, 190, 0.7);
  border-radius: 28rpx;
  background: #fffdfa;
  box-sizing: border-box;
}

.customer-product-detail__chip--active {
  border-color: rgba(225, 122, 94, 0.66);
  box-shadow: 0 12rpx 24rpx rgba(215, 93, 63, 0.12);
}

.customer-product-detail__chip-meta {
  font-size: 22rpx;
  line-height: 1.4;
  color: #8a675e;
}

.customer-product-detail__detail-image + .customer-product-detail__detail-image {
  margin-top: 20rpx;
}

.customer-product-detail__detail-media {
  width: 100%;
}

.customer-product-detail__footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 112rpx 112rpx 1fr 1fr;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 249, 246, 0.94);
  box-shadow: 0 -14rpx 36rpx rgba(166, 120, 102, 0.14);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}

.customer-product-detail__nav-button {
  min-width: 0;
}

.customer-product-detail__action-button {
  min-width: 0;
}
