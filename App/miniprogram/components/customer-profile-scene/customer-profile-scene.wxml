<view class="customer-profile-scene">
  <view class="glass-card customer-profile-scene__hero">
    <view class="customer-profile-scene__hero-head">
      <view class="customer-profile-scene__avatar-shell">
        <text class="customer-profile-scene__avatar-label">头像</text>
        <view class="customer-profile-scene__avatar-fallback" wx:if="{{!session.avatarUrl}}">{{avatarText}}</view>
        <t-image
          wx:else
          class="customer-profile-scene__avatar-image"
          src="{{session.avatarUrl}}"
          mode="aspectFill"
          shape="round"
          lazy="{{true}}"
        ></t-image>
      </view>

      <view class="customer-profile-scene__hero-copy">
        <text class="customer-profile-scene__title">{{session.nickname}}</text>
        <text class="customer-profile-scene__subtitle">
          {{session.isLoggedIn ? '关键动作已启用微信登录门禁，可直接加购与提交订单。' : '当前为游客浏览，加入购物车、立即购买与结算前会先拉起微信登录。'}}
        </text>
        <view class="customer-profile-scene__tag-row">
          <t-tag theme="{{session.isLoggedIn ? 'primary' : 'default'}}" variant="light">登录状态：{{statusLabel}}</t-tag>
          <t-tag wx:if="{{isPreviewMode}}" theme="warning" variant="light">管理员预览</t-tag>
        </view>
      </view>
    </view>

    <view class="customer-profile-scene__actions">
      <view
        class="customer-profile-scene__action-button customer-profile-scene__action-button--{{session.isLoggedIn ? 'disabled' : 'primary'}}"
        bindtap="handleLoginTap"
      >微信登录</view>
      <view
        class="customer-profile-scene__action-button customer-profile-scene__action-button--{{session.isLoggedIn ? 'default' : 'disabled'}}"
        bindtap="handleLogoutTap"
      >退出登录</view>
      <view
        class="customer-profile-scene__action-button customer-profile-scene__action-button--outline"
        bindtap="handleSettingsTap"
      >设置</view>
    </view>
  </view>

  <view class="glass-card customer-profile-scene__section">
    <text class="customer-profile-scene__section-title">本地账号说明</text>
    <t-cell-group>
      <t-cell
        title="登录门禁"
        note="{{session.isLoggedIn ? '已开启' : '未登录'}}"
        description="浏览首页、订单与详情可免登录；加购、立即购买、去结算和提交订单会先校验微信登录。"
        t-class-title="app-interactive-text"
        t-class-note="app-interactive-text"
      ></t-cell>
      <t-cell
        title="本地闭环"
        note="当前轮次"
        description="购物车、订单、手机号历史均保存在本机缓存，云端联动后置。"
        t-class-title="app-interactive-text"
        t-class-note="app-interactive-text"
      ></t-cell>
    </t-cell-group>
  </view>

  <view class="glass-card customer-profile-scene__section" wx:if="{{canBackToAdmin}}">
    <text class="customer-profile-scene__section-title">预览切换</text>
    <view
      class="customer-profile-scene__action-button customer-profile-scene__action-button--outline"
      style="width: 100%;"
      bindtap="handlePreviewReturnTap"
    >返回管理员视角</view>
  </view>
</view>
