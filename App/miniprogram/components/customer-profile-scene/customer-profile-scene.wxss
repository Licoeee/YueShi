.customer-profile-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.customer-profile-scene__hero,
.customer-profile-scene__section {
  padding: 24rpx;
}

.customer-profile-scene__section {
  margin-top: 22rpx;
}

.customer-profile-scene__recycle-section {
  border: 1px solid rgba(247, 191, 201, 0.92);
  background: linear-gradient(180deg, rgba(255, 241, 244, 0.96) 0%, rgba(255, 252, 252, 0.96) 100%);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.customer-profile-scene__recycle-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.customer-profile-scene__recycle-symbol {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  flex: none;
  border-radius: 22rpx;
  background: linear-gradient(160deg, rgba(255, 150, 123, 0.2) 0%, rgba(255, 185, 149, 0.32) 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}

.customer-profile-scene__recycle-lid {
  position: absolute;
  left: 20rpx;
  top: 18rpx;
  width: 44rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
}

.customer-profile-scene__recycle-body {
  position: absolute;
  left: 24rpx;
  top: 30rpx;
  width: 36rpx;
  height: 34rpx;
  border-radius: 12rpx 12rpx 14rpx 14rpx;
  background: linear-gradient(150deg, #ff8a69 0%, #feb47b 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
}

.customer-profile-scene__recycle-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.customer-profile-scene__recycle-title {
  color: #5b3934;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-profile-scene__recycle-desc {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 600;
}

.customer-profile-scene__hero-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.customer-profile-scene__avatar-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: none;
}

.customer-profile-scene__avatar-label {
  color: #8b665f;
  font-size: 22rpx;
  font-weight: 600;
}

.customer-profile-scene__avatar-image,
.customer-profile-scene__avatar-fallback {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
}

.customer-profile-scene__avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ff9d7b 0%, #ff7a63 100%);
  box-shadow: 0 16rpx 28rpx rgba(186, 112, 95, 0.18);
}

.customer-profile-scene__hero-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 12rpx;
}

.customer-profile-scene__title {
  color: #563733;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-profile-scene__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 600;
}

.customer-profile-scene__tag-row,
.customer-profile-scene__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.customer-profile-scene__actions {
  margin-top: 24rpx;
  justify-content: flex-end;
}

.customer-profile-scene__section-title {
  display: block;
  margin-bottom: 18rpx;
  color: #5b3934;
  font-size: 28rpx;
  font-weight: 700;
}

.customer-profile-scene__cell-note {
  flex: none;
  min-width: 128rpx;
  color: #b06251;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

.customer-profile-scene__recycle-entry-button {
  --td-button-border-radius: 20rpx;
  --td-button-primary-color: #fffdfa;
  --td-button-primary-bg-color: #ff8a69;
  --td-button-primary-border-color: rgba(255, 170, 136, 0.8);
  --td-button-primary-active-bg-color: #f7795c;
  --td-button-primary-active-border-color: rgba(242, 120, 87, 0.92);
  --td-button-primary-disabled-color: rgba(255, 255, 255, 0.92);
  --td-button-primary-disabled-bg: rgba(227, 192, 184, 0.92);
  --td-button-primary-disabled-border-color: rgba(227, 192, 184, 0.92);
}

.customer-profile-scene__action-button {
  min-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.01em;
  white-space: nowrap;
  box-sizing: border-box;
}

.customer-profile-scene__action-button--outline {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.customer-profile-scene__action-button--default {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.customer-profile-scene__action-button--primary {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.56), 0 20rpx 44rpx rgba(243, 122, 87, 0.24);
}

.customer-profile-scene__action-button--disabled {
  color: rgba(145, 116, 109, 0.82);
  background: rgba(244, 230, 226, 0.94);
  border: 1rpx solid rgba(221, 194, 186, 0.88);
  box-shadow: none;
  pointer-events: none;
}
