.foundation-shell {
  position: relative;
  min-height: 100vh;
}

.foundation-shell__background {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: radial-gradient(circle at 50% 40%, #fff5f7 0%, #ffd1dc 60%, #feb47b 120%);
}

.foundation-shell__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  padding-bottom: 48rpx;
}

.hero-panel,
.checklist-panel,
.action-panel {
  padding: 30rpx;
}

.hero-panel__eyebrow {
  display: block;
  margin-bottom: 18rpx;
  color: rgba(122, 74, 67, 0.72);
  font-size: 22rpx;
  letter-spacing: 0.18em;
}

.hero-panel__heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.hero-panel__title {
  color: #ffffff;
  font-size: 68rpx;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-shadow: 0 8rpx 16rpx rgba(200, 100, 100, 0.4);
}

.hero-panel__slogan {
  display: block;
  margin-bottom: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  letter-spacing: 0.15em;
}

.hero-panel {
  background: linear-gradient(150deg, rgba(255, 126, 95, 0.94) 0%, rgba(254, 180, 123, 0.92) 55%, rgba(255, 209, 220, 0.82) 100%);
}

.hero-panel__meta {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.hero-panel__meta-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  box-shadow: 0 0 0 6rpx rgba(255, 255, 255, 0.2);
}

.hero-panel__meta-text {
  margin-left: 12rpx;
  color: rgba(122, 74, 67, 0.88);
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-panel__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
  margin-right: -16rpx;
  margin-bottom: -16rpx;
}

.hero-panel__tag-item {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.checklist-panel {
  padding: 0;
}

.role-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.role-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.role-card__role {
  display: block;
  margin-top: 18rpx;
  color: var(--color-sunset);
  font-size: 28rpx;
  font-weight: 600;
  text-transform: capitalize;
}

.role-card__description {
  display: block;
  margin-top: 12rpx;
  color: rgba(122, 74, 67, 0.82);
  font-size: 24rpx;
  line-height: 1.7;
}

.action-panel__title {
  display: block;
  margin-bottom: 16rpx;
  color: #7a4a43;
  font-size: 32rpx;
  font-weight: 600;
}

.action-panel__description {
  display: block;
  margin-bottom: 24rpx;
  color: rgba(122, 74, 67, 0.8);
  font-size: 24rpx;
  line-height: 1.7;
}

.action-panel__button-item + .action-panel__button-item {
  margin-top: 16rpx;
}

.foundation-shell--preview {
  pointer-events: none;
}

.foundation-shell--preview .foundation-shell__content {
  padding-top: 24rpx;
}

@media (max-width: 640rpx) {
  .role-card {
    width: calc(100% - 20rpx);
  }
}
