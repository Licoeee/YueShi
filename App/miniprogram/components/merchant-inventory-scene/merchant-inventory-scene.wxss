@import "../../styles/merchant-button-token.wxss";

.merchant-inventory-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.merchant-inventory-scene__hero {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.merchant-inventory-scene__title {
  color: #553633;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
}

.merchant-inventory-scene__tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.merchant-inventory-scene__action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.merchant-inventory-scene__btn {
  --td-button-small-height: 58rpx;
  --td-button-small-padding-horizontal: 18rpx;
  --td-button-small-font-size: 22rpx;
}

.merchant-inventory-scene__empty {
  margin-top: 18rpx;
  padding: 26rpx 20rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 26rpx rgba(188, 113, 96, 0.11);
}

.merchant-inventory-scene__list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.merchant-inventory-scene__card {
  border-radius: 20rpx;
  border: 1px solid rgba(244, 210, 198, 0.95);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 24rpx rgba(188, 113, 96, 0.11);
  padding: 14rpx;
}

.merchant-inventory-scene__card--near {
  border-color: rgba(246, 190, 151, 0.92);
  background: linear-gradient(180deg, rgba(255, 245, 236, 0.97) 0%, rgba(255, 253, 250, 0.97) 100%);
}

.merchant-inventory-scene__item-row {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
}

.merchant-inventory-scene__card-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  border: 1px solid rgba(242, 210, 199, 0.95);
}

.merchant-inventory-scene__item-body {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.merchant-inventory-scene__card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.merchant-inventory-scene__item-name {
  color: #563733;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.merchant-inventory-scene__meta-line {
  color: #7a5952;
  font-size: 20rpx;
  line-height: 1.5;
}

.merchant-inventory-scene__card-actions {
  margin-top: 12rpx;
}

.merchant-inventory-scene__popup {
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  padding: 22rpx;
  max-height: 78vh;
  overflow-y: auto;
}

.merchant-inventory-scene__popup-title {
  display: block;
  color: #553633;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.merchant-inventory-scene__field-cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 252, 250, 0.96);
}

.merchant-inventory-scene__field-cell--readonly {
  background: rgba(255, 247, 242, 0.96);
}

.merchant-inventory-scene__field-label {
  color: #7a5952;
  font-size: 22rpx;
}

.merchant-inventory-scene__field-value {
  color: #563733;
  font-size: 22rpx;
  font-weight: 600;
}

.merchant-inventory-scene__photo-row {
  margin-top: 14rpx;
}

.merchant-inventory-scene__photo-preview {
  margin-top: 10rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 18rpx;
}

.merchant-inventory-scene__popup-actions {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
