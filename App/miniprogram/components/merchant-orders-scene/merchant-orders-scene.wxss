@import "../../styles/merchant-button-token.wxss";

.merchant-orders-scene {
  min-height: 100%;
  padding: 0 0 calc(188rpx + env(safe-area-inset-bottom));
}

.merchant-orders-scene__hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
}

.merchant-orders-scene__title {
  color: #553633;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
}

.merchant-orders-scene__tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.merchant-orders-scene__search {
  margin-top: 4rpx;
}

.merchant-orders-scene__status-tabs {
  margin-top: 4rpx;
  padding: 10rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 251, 249, 0.84);
  box-shadow: 0 14rpx 28rpx rgba(184, 111, 95, 0.1);
}

.merchant-orders-scene__tab-list {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
}

.merchant-orders-scene__tab-item {
  display: flex;
  flex: 1;
  min-width: 0;
  padding: 4rpx;
  border-radius: 999rpx;
}

.merchant-orders-scene__tab-item--active {
  background: linear-gradient(135deg, rgba(255, 236, 227, 0.94) 0%, rgba(255, 244, 240, 0.98) 100%);
  box-shadow: inset 0 0 0 1px rgba(240, 179, 157, 0.42);
}

.merchant-orders-scene__filter-tag {
  display: flex;
  width: 100%;
  justify-content: center;
}

.merchant-orders-scene__tab-item .t-tag {
  width: 100%;
}

.merchant-orders-scene__filter-tag .t-tag__text {
  flex: 1;
  text-align: center;
}

.merchant-orders-scene__action-row {
  display: flex;
  gap: 10rpx;
  margin-top: 2rpx;
}

.merchant-orders-scene__action-row t-button {
  flex: 1 1 0;
  min-width: 0;
}

.merchant-orders-scene__utility-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.merchant-orders-scene__utility-entry {
  flex: 1 1 0;
  min-width: 0;
}

.merchant-orders-scene__recycle-entry {
  display: flex;
}

.merchant-orders-scene__utility-entry t-button {
  width: 100%;
}

.merchant-orders-scene__utility-btn {
  width: 100%;
  --td-button-small-height: 56rpx;
  --td-button-small-padding-horizontal: 18rpx;
  --td-button-small-font-size: 22rpx;
}

.merchant-orders-scene__btn,
.merchant-orders-scene__action-btn {
  --td-button-small-height: 58rpx;
  --td-button-small-padding-horizontal: 18rpx;
  --td-button-small-font-size: 22rpx;
}

.merchant-orders-scene__action-btn {
  min-width: 208rpx;
}

.merchant-orders-scene__empty {
  margin-top: 18rpx;
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 26rpx rgba(188, 113, 96, 0.11);
}

.merchant-orders-scene__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.merchant-orders-scene__card {
  position: relative;
  padding: 18rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 24rpx rgba(188, 113, 96, 0.11);
}

.merchant-orders-scene__card--noted {
  border-color: rgba(247, 191, 201, 0.95);
  background: linear-gradient(180deg, rgba(255, 241, 244, 0.98) 0%, rgba(255, 252, 252, 0.98) 100%);
}

.merchant-orders-scene__card-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.merchant-orders-scene__cover-shell {
  flex: none;
}

.merchant-orders-scene__cover {
  width: 124rpx;
  height: 124rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255, 245, 242, 0.95);
  border: 1px solid rgba(244, 210, 198, 0.78);
}

.merchant-orders-scene__card-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merchant-orders-scene__tag-stack {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.merchant-orders-scene__order-id {
  color: #5b3a35;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.merchant-orders-scene__item-summary {
  color: #6f4f49;
  font-size: 22rpx;
  line-height: 1.55;
}

.merchant-orders-scene__item-quantity {
  color: #b06251;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.4;
}

.merchant-orders-scene__meta-row {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 14rpx;
}

.merchant-orders-scene__meta-label {
  color: #8c6a63;
  font-size: 20rpx;
  flex: none;
  min-width: 92rpx;
}

.merchant-orders-scene__meta-value {
  color: #563733;
  font-size: 20rpx;
  flex: 1;
  min-width: 0;
  text-align: right;
  line-height: 1.5;
}

.merchant-orders-scene__note {
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 233, 239, 0.84);
  border: 1rpx solid rgba(246, 179, 194, 0.86);
}

.merchant-orders-scene__note-label {
  display: block;
  color: #9a4e60;
  font-size: 20rpx;
  font-weight: 600;
}

.merchant-orders-scene__note-value {
  display: block;
  margin-top: 6rpx;
  color: #6f4f49;
  font-size: 20rpx;
  line-height: 1.5;
}

.merchant-orders-scene__card-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.merchant-orders-scene__popup-shell {
  padding: 24rpx 22rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
}

.merchant-orders-scene__popup-head {
  padding-bottom: 14rpx;
  border-bottom: 1px solid rgba(244, 210, 198, 0.72);
}

.merchant-orders-scene__popup-title {
  color: #553633;
  font-size: 30rpx;
  font-weight: 700;
}

.merchant-orders-scene__popup-body {
  margin-top: 16rpx;
}

.merchant-orders-scene__cleanup-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.merchant-orders-scene__cleanup-item {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 251, 249, 0.95);
}

.merchant-orders-scene__cleanup-radio {
  --td-radio-icon-size: 36rpx;
  --td-radio-label-line-height: 40rpx;
}

.merchant-orders-scene__cleanup-label {
  color: #553633;
  font-size: 22rpx;
  font-weight: 600;
}

.merchant-orders-scene__popup-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.merchant-orders-scene__popup-action-btn {
  flex: 1 1 0;
  min-width: 0;
  --td-button-small-height: 64rpx;
  --td-button-small-padding-horizontal: 18rpx;
  --td-button-small-font-size: 24rpx;
}

.merchant-orders-scene__popup-note {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 244, 240, 0.9);
  border: 1px solid rgba(244, 210, 198, 0.9);
}

.merchant-orders-scene__popup-note-text {
  color: #7a5952;
  font-size: 21rpx;
  line-height: 1.6;
}

.merchant-orders-scene__dialog-shell {
  width: min(640rpx, calc(100vw - 64rpx));
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 251, 248, 0.98) 0%, rgba(255, 244, 240, 0.98) 100%);
  box-shadow: 0 20rpx 42rpx rgba(188, 113, 96, 0.2);
  box-sizing: border-box;
}

.merchant-orders-scene__dialog-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.merchant-orders-scene__dialog-title {
  color: #553633;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.merchant-orders-scene__dialog-copy {
  color: #7a5952;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}

.merchant-orders-scene__dialog-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.merchant-orders-scene__dialog-btn {
  flex: 1 1 0;
  min-width: 0;
  --td-button-small-height: 62rpx;
  --td-button-small-padding-horizontal: 20rpx;
  --td-button-small-font-size: 24rpx;
}

.merchant-orders-scene__calendar {
  --td-calendar-panel-height: 80vh;
  --td-calendar-bg-color: #fffaf7;
  --td-calendar-title-color: #553633;
  --td-calendar-active-color: #ff835f;
  --td-calendar-selected-color: #fffdfa;
  --td-calendar-days-color: #8c6a63;
  --td-calendar-item-centre-color: rgba(255, 236, 227, 0.92);
  --td-calendar-item-disabled-color: rgba(191, 167, 159, 0.72);
  --td-button-primary-bg-color: #ff835f;
  --td-button-primary-border-color: rgba(255, 163, 126, 0.92);
  --td-button-primary-active-bg-color: #f66d4d;
  --td-button-primary-active-border-color: rgba(245, 116, 83, 0.94);
  --td-button-primary-color: #fffdfa;
  max-height: 80vh;
}
