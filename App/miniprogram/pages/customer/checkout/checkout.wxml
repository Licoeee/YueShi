<view class="checkout-page">
  <view class="checkout-page__background"></view>

  <view class="checkout-page__content">
    <view class="glass-card checkout-page__hero">
      <text class="checkout-page__eyebrow">CHECKOUT</text>
      <text class="checkout-page__title">提交订单</text>
      <text class="checkout-page__subtitle">本次共 {{totalQuantity}} 件蛋糕，确认手机号和取货时间后即可生成待支付订单。</text>
    </view>

    <view class="glass-card checkout-page__section" wx:if="{{checkoutItems.length === 0}}">
      <t-empty description="当前没有可结算的蛋糕"></t-empty>
    </view>

    <block wx:else>
      <view class="glass-card checkout-page__section">
        <text class="checkout-page__section-title">本次商品</text>

        <view wx:for="{{checkoutItems}}" wx:key="id" class="checkout-page__item">
          <t-image
            class="checkout-page__item-cover"
            src="{{item.coverImageUrl}}"
            mode="aspectFill"
            shape="round"
            lazy="{{true}}"
          ></t-image>
          <view class="checkout-page__item-copy">
            <text class="checkout-page__item-name">{{item.productName}}</text>
            <text class="checkout-page__item-spec">{{item.specLabel}}</text>
            <text class="checkout-page__item-cream">{{item.creamLabel}}</text>
          </view>
          <view class="checkout-page__item-side">
            <t-tag theme="primary" variant="light">x{{item.quantity}}</t-tag>
            <text class="checkout-page__item-price">¥ {{item.subtotal}}</text>
          </view>
        </view>
      </view>

      <view class="glass-card checkout-page__section">
        <text class="checkout-page__section-title">联系信息</text>
        <view class="checkout-page__contact-row">
          <t-input
            label="手机号"
            type="number"
            maxlength="11"
            placeholder="请手动输入联系电话"
            value="{{phone}}"
            borderless="{{true}}"
            bind:change="handlePhoneChange"
          ></t-input>
          <t-button
            wx:if="{{phoneHistoryItems.length > 0}}"
            t-class="checkout-page__history-button"
            theme="primary"
            variant="outline"
            size="small"
            bindtap="handleOpenPhoneHistory"
          >历史手机号</t-button>
        </view>
        <text class="checkout-page__error" wx:if="{{phoneError.length > 0}}">{{phoneError}}</text>
      </view>

      <view class="glass-card checkout-page__section">
        <text class="checkout-page__section-title">取货时间</text>
        <t-cell title="取货时间" note="{{pickupSummary}}" bindtap="handleOpenPickupPicker"></t-cell>
        <text class="checkout-page__error" wx:if="{{pickupError.length > 0}}">{{pickupError}}</text>
      </view>
    </block>
  </view>

  <view class="checkout-page__footer">
    <view class="checkout-page__footer-main">
      <view class="checkout-page__footer-copy">
        <text class="checkout-page__footer-label">合计</text>
        <text class="checkout-page__footer-price">¥ {{totalAmount}}</text>
      </view>
    </view>
    <t-button
      t-class="checkout-page__submit-button"
      theme="primary"
      size="large"
      disabled="{{checkoutItems.length === 0}}"
      bindtap="handleSubmit"
    >提交订单</t-button>
  </view>

  <t-picker
    visible="{{pickupPickerVisible}}"
    title="选择取货时间"
    value="{{pickupPickerValue}}"
    bind:pick="handlePickupPick"
    bind:confirm="handlePickupConfirm"
    bind:cancel="handlePickupCancel"
  >
    <t-picker-item options="{{pickupPickerState.monthOptions}}"></t-picker-item>
    <t-picker-item options="{{pickupPickerState.dayOptions}}"></t-picker-item>
    <t-picker-item options="{{pickupPickerState.timeOptions}}"></t-picker-item>
  </t-picker>

  <t-dialog
    visible="{{paymentGuideVisible}}"
    title="付款提示"
    content="{{paymentGuideText}}"
    confirmBtn="我知道了"
    bind:confirm="handlePaymentGuideConfirm"
  ></t-dialog>

  <t-action-sheet
    visible="{{phoneHistoryVisible}}"
    items="{{phoneHistoryItems}}"
    description="选择历史手机号"
    bind:selected="handleSelectPhoneHistory"
    bind:cancel="handleClosePhoneHistory"
    bind:close="handleClosePhoneHistory"
  ></t-action-sheet>
</view>
