.checkout-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.checkout-page__background {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 16% 12%, rgba(255, 255, 255, 0.54) 0%, rgba(255, 255, 255, 0) 42%),
    radial-gradient(circle at 84% 8%, rgba(255, 232, 220, 0.58) 0%, rgba(255, 232, 220, 0) 40%),
    linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.checkout-page__content {
  position: relative;
  z-index: 1;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx calc(224rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.checkout-page__hero {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 28rpx;
}

.checkout-page__eyebrow {
  color: rgba(122, 74, 67, 0.68);
  font-size: 22rpx;
  letter-spacing: 0.16em;
}

.checkout-page__title {
  color: #573733;
  font-size: 48rpx;
  font-weight: 700;
}

.checkout-page__subtitle {
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 600;
}

.checkout-page__section {
  margin-top: 22rpx;
  padding: 24rpx;
}

.checkout-page__section-title {
  display: block;
  margin-bottom: 18rpx;
  color: #5b3934;
  font-size: 28rpx;
  font-weight: 700;
}

.checkout-page__item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.checkout-page__item + .checkout-page__item {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(233, 205, 197, 0.7);
}

.checkout-page__item-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.checkout-page__item-name {
  color: #5a3834;
  font-size: 28rpx;
  font-weight: 700;
}

.checkout-page__item-spec {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.checkout-page__item-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.checkout-page__item-price {
  color: #cc4f2f;
  font-size: 28rpx;
  font-weight: 700;
}

.checkout-page__error {
  display: block;
  margin-top: 12rpx;
  color: #d04f4a;
  font-size: 22rpx;
}

.checkout-page__footer {
  position: fixed;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: 30rpx;
  background: rgba(255, 252, 250, 0.94);
  box-shadow: 0 20rpx 38rpx rgba(179, 103, 89, 0.16);
  backdrop-filter: blur(24rpx);
}

.checkout-page__footer-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.checkout-page__footer-label {
  color: #80605a;
  font-size: 22rpx;
  font-weight: 600;
}

.checkout-page__footer-price {
  color: #cb4d2d;
  font-size: 38rpx;
  font-weight: 700;
}
