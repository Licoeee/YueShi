.order-detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.order-detail-page__background {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.56) 0%, rgba(255, 255, 255, 0) 40%),
    radial-gradient(circle at 82% 8%, rgba(255, 230, 223, 0.58) 0%, rgba(255, 230, 223, 0) 42%),
    linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.order-detail-page__content {
  position: relative;
  z-index: 1;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.order-detail-page__hero,
.order-detail-page__section {
  padding: 24rpx;
}

.order-detail-page__section {
  margin-top: 22rpx;
}

.order-detail-page__hero-head,
.order-detail-page__section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-detail-page__hero-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 12rpx;
}

.order-detail-page__eyebrow {
  color: rgba(122, 74, 67, 0.68);
  font-size: 22rpx;
  letter-spacing: 0.16em;
}

.order-detail-page__title {
  color: #573733;
  font-size: 42rpx;
  font-weight: 700;
}

.order-detail-page__subtitle {
  display: block;
  margin-top: 14rpx;
  color: #70514b;
  font-size: 24rpx;
  line-height: 1.6;
}

.order-detail-page__section-title {
  color: #5b3a35;
  font-size: 28rpx;
  font-weight: 700;
}

.order-detail-page__item + .order-detail-page__item {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1px solid rgba(235, 208, 201, 0.78);
}

.order-detail-page__item-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.order-detail-page__item-name {
  color: #593934;
  font-size: 28rpx;
  font-weight: 700;
}

.order-detail-page__item-spec,
.order-detail-page__hint,
.order-detail-page__note-text {
  color: #76554f;
  font-size: 24rpx;
  line-height: 1.7;
}

.order-detail-page__item-price {
  display: block;
  margin-top: 12rpx;
  color: #cc4f2f;
  font-size: 26rpx;
  font-weight: 700;
}

.order-detail-page__note-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}
