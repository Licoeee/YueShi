<view class="order-recycle-page">
  <view class="order-recycle-page__background"></view>

  <view class="order-recycle-page__content">
    <view class="glass-card order-recycle-page__hero">
      <view class="order-recycle-page__hero-head">
        <view class="order-recycle-page__trash-shell" aria-hidden="true">
          <view class="order-recycle-page__trash-lid"></view>
          <view class="order-recycle-page__trash-body"></view>
        </view>
        <view class="order-recycle-page__hero-copy">
          <text class="order-recycle-page__title">删除订单</text>
          <text class="order-recycle-page__subtitle">订单回收站（垃圾桶）会保留已删除订单，支持 7 天内恢复。</text>
          <view class="order-recycle-page__hero-tags">
            <t-tag theme="danger" variant="light">垃圾桶语义</t-tag>
            <t-tag theme="warning" variant="light">7 天恢复期</t-tag>
          </view>
        </view>
      </view>
    </view>

    <view class="order-recycle-page__empty" wx:if="{{deletedOrders.length === 0}}">
      <t-empty description="暂无已删除订单"></t-empty>
    </view>

    <view class="order-recycle-page__list" wx:else>
      <view wx:for="{{deletedOrders}}" wx:key="id" class="order-recycle-page__card">
        <view class="order-recycle-page__card-head">
          <view class="order-recycle-page__cover-shell">
            <t-image
              class="order-recycle-page__cover"
              src="{{item.coverImageUrl}}"
              mode="aspectFill"
              shape="round"
              lazy="{{true}}"
            ></t-image>
          </view>

          <view class="order-recycle-page__card-copy">
            <text class="order-recycle-page__order-id">订单号 {{item.id}}</text>
            <text class="order-recycle-page__item-summary">{{item.itemSummary}}</text>
            <text class="order-recycle-page__item-quantity">{{item.itemQuantitySummary}}</text>
          </view>

          <view class="order-recycle-page__tag-stack">
            <t-tag theme="default" variant="light">{{item.statusLabel}}</t-tag>
            <t-tag theme="warning" variant="light">{{item.recoverRemainingLabel}}</t-tag>
          </view>
        </view>

        <view class="order-recycle-page__meta-row">
          <text class="order-recycle-page__meta-label">删除时间</text>
          <text class="order-recycle-page__meta-value">{{item.deletedAtLabel}}</text>
        </view>
        <view class="order-recycle-page__meta-row">
          <text class="order-recycle-page__meta-label">恢复截止</text>
          <text class="order-recycle-page__meta-value">{{item.recoverDeadlineLabel}}</text>
        </view>
        <view class="order-recycle-page__meta-row">
          <text class="order-recycle-page__meta-label">取货时间</text>
          <text class="order-recycle-page__meta-value">{{item.pickupSummary}}</text>
        </view>
        <view class="order-recycle-page__meta-row">
          <text class="order-recycle-page__meta-label">合计金额</text>
          <text class="order-recycle-page__meta-value">¥ {{item.totalAmount}}</text>
        </view>

        <view class="order-recycle-page__actions">
          <t-button
            theme="primary"
            block="{{true}}"
            disabled="{{!item.canRestore}}"
            t-class="order-recycle-page__restore-button"
            data-order-id="{{item.id}}"
            data-can-restore="{{item.canRestore}}"
            bindtap="handleRestoreTap"
          >
            恢复订单
          </t-button>
        </view>
      </view>
    </view>
  </view>
</view>
