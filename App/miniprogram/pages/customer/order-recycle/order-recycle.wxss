.order-recycle-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.order-recycle-page__background {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.56) 0%, rgba(255, 255, 255, 0) 40%),
    radial-gradient(circle at 82% 8%, rgba(255, 230, 223, 0.58) 0%, rgba(255, 230, 223, 0) 42%),
    linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.order-recycle-page__content {
  position: relative;
  z-index: 1;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.order-recycle-page__hero {
  padding: 24rpx;
}

.order-recycle-page__hero-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.order-recycle-page__trash-shell {
  position: relative;
  width: 94rpx;
  height: 94rpx;
  flex: none;
  border-radius: 24rpx;
  background: linear-gradient(160deg, rgba(255, 150, 123, 0.2) 0%, rgba(255, 185, 149, 0.34) 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}

.order-recycle-page__trash-lid {
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 50rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
}

.order-recycle-page__trash-body {
  position: absolute;
  left: 27rpx;
  top: 34rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 14rpx 14rpx 16rpx 16rpx;
  background: linear-gradient(150deg, #ff8a69 0%, #feb47b 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
}

.order-recycle-page__hero-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.order-recycle-page__title {
  display: block;
  color: #553633;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.order-recycle-page__subtitle {
  display: block;
  margin-top: 14rpx;
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 600;
}

.order-recycle-page__hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.order-recycle-page__empty {
  margin-top: 24rpx;
  padding: 38rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(188, 113, 96, 0.12);
}

.order-recycle-page__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.order-recycle-page__card {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1px solid rgba(244, 210, 198, 0.9);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(188, 113, 96, 0.12);
}

.order-recycle-page__card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-recycle-page__cover-shell {
  flex: none;
}

.order-recycle-page__cover {
  width: 132rpx;
  height: 132rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 245, 242, 0.95);
}

.order-recycle-page__tag-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.order-recycle-page__card-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.order-recycle-page__order-id {
  color: #5b3a35;
  font-size: 24rpx;
  font-weight: 700;
}

.order-recycle-page__item-summary {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.order-recycle-page__item-quantity {
  color: #b06251;
  font-size: 22rpx;
  font-weight: 600;
}

.order-recycle-page__meta-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
}

.order-recycle-page__meta-label {
  color: #8c6a63;
  font-size: 22rpx;
}

.order-recycle-page__meta-value {
  color: #563733;
  font-size: 24rpx;
  font-weight: 600;
}

.order-recycle-page__actions {
  margin-top: 18rpx;
}

.order-recycle-page__restore-button {
  --td-button-border-radius: 18rpx;
  --td-button-primary-color: #fffdfa;
  --td-button-primary-bg-color: #ff8a69;
  --td-button-primary-border-color: rgba(255, 170, 136, 0.8);
  --td-button-primary-active-bg-color: #f7795c;
  --td-button-primary-active-border-color: rgba(242, 120, 87, 0.92);
  --td-button-primary-disabled-color: rgba(255, 255, 255, 0.92);
  --td-button-primary-disabled-bg: rgba(227, 192, 184, 0.92);
  --td-button-primary-disabled-border-color: rgba(227, 192, 184, 0.92);
}
