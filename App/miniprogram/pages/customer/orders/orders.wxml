<view class="role-page">
  <view class="role-page__background"></view>
  <view
    class="role-page__scene-host role-page__scene-host--{{sceneDirection}} role-page__scene-host--tick-{{sceneMotionTick % 2}}"
  >
    <role-page-scene
      scenePath="{{scenePath}}"
      activeRole="{{activeRole}}"
      isPreviewMode="{{isPreviewMode}}"
      canBackToAdmin="{{canBackToAdmin}}"
      cartRefreshTick="{{cartRefreshTick}}"
      bind:sceneaction="handleSceneAction"
    ></role-page-scene>
  </view>

  <custom-tab-bar
    role="{{activeRole}}"
    mode="scene"
    currentPath="{{scenePath}}"
    bind:tabchange="handleTabChange"
  ></custom-tab-bar>
</view>

<t-dialog
  visible="{{deleteDialogVisible}}"
  title="删除商品"
  content="确认从购物车删除这件蛋糕吗？删除后需要重新选择规格才能再次加入。"
  confirmBtn="确认删除"
  cancelBtn="我再想想"
  bind:confirm="handleConfirmDelete"
  bind:cancel="handleCloseDeleteDialog"
  bind:close="handleCloseDeleteDialog"
></t-dialog>
