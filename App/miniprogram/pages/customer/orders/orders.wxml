<view class="role-page">
  <view class="role-page__background"></view>
  <view
    class="role-page__scene-host role-page__scene-host--{{sceneDirection}} role-page__scene-host--tick-{{sceneMotionTick % 2}}"
  >
    <role-page-scene
      scenePath="{{scenePath}}"
      activeRole="{{activeRole}}"
      isPreviewMode="{{isPreviewMode}}"
      canBackToAdmin="{{canBackToAdmin}}"
      bind:sceneaction="handleSceneAction"
    ></role-page-scene>
  </view>

  <custom-tab-bar
    role="{{activeRole}}"
    mode="scene"
    currentPath="{{scenePath}}"
    bind:tabchange="handleTabChange"
  ></custom-tab-bar>
</view>
