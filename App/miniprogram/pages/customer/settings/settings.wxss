.settings-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.settings-page__background {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.56) 0%, rgba(255, 255, 255, 0) 40%),
    radial-gradient(circle at 82% 8%, rgba(255, 230, 223, 0.58) 0%, rgba(255, 230, 223, 0) 42%),
    linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.settings-page__content {
  position: relative;
  z-index: 1;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.settings-page__hero,
.settings-page__section {
  padding: 24rpx;
}

.settings-page__section {
  margin-top: 22rpx;
}

.settings-page__eyebrow {
  color: rgba(122, 74, 67, 0.68);
  font-size: 22rpx;
  letter-spacing: 0.16em;
}

.settings-page__title {
  display: block;
  margin-top: 14rpx;
  color: #573733;
  font-size: 48rpx;
  font-weight: 700;
}

.settings-page__subtitle {
  display: block;
  margin-top: 14rpx;
  color: #6f4f49;
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 600;
}

.settings-page__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.settings-page__section-title {
  color: #5b3934;
  font-size: 28rpx;
  font-weight: 700;
}

.settings-page__account-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border: 1px solid rgba(239, 209, 200, 0.92);
  border-radius: 24rpx;
  background: rgba(255, 249, 246, 0.97);
  box-shadow: 0 14rpx 26rpx rgba(188, 111, 95, 0.1), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.72);
}

.settings-page__account-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.settings-page__account-label {
  color: #8b665f;
  font-size: 22rpx;
  font-weight: 600;
}

.settings-page__account-name {
  color: #593934;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  word-break: break-all;
}

.settings-page__account-desc {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.settings-page__action-card,
.settings-page__history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
}

.settings-page__action-card + .settings-page__action-card,
.settings-page__history-item + .settings-page__history-item {
  border-top: 1px solid rgba(233, 205, 197, 0.72);
}

.settings-page__action-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.settings-page__action-title,
.settings-page__history-phone {
  color: #593934;
  font-size: 28rpx;
  font-weight: 700;
}

.settings-page__action-desc,
.settings-page__empty-text {
  color: #76554f;
  font-size: 22rpx;
  line-height: 1.6;
}

.settings-page__history-list {
  display: flex;
  flex-direction: column;
}

.settings-page__empty {
  padding: 16rpx 0 6rpx;
}

.settings-page__action-button {
  min-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.01em;
  white-space: nowrap;
  box-sizing: border-box;
}

.settings-page__cell-note {
  flex: none;
  min-width: 128rpx;
  color: #b06251;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

.settings-page__action-button--outline {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.settings-page__action-button--danger {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.settings-page__action-button--ghost {
  color: #fffdfa;
  background: linear-gradient(135deg, #ff8a69 0%, #feb47b 100%);
  border: 1rpx solid rgba(255, 170, 136, 0.78);
  box-shadow: 0 20rpx 44rpx rgba(243, 122, 87, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}
