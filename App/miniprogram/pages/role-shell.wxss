page {
  min-height: 100%;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
  background-color: #fff5f7;
}

.role-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.role-page__background {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 16% 10%, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0) 42%),
    radial-gradient(circle at 82% 8%, rgba(255, 232, 220, 0.56) 0%, rgba(255, 232, 220, 0) 40%),
    linear-gradient(180deg, #fff5f7 0%, #ffe5d6 100%);
}

.role-page__content {
  position: relative;
  z-index: 1;
  padding: calc(30rpx + env(safe-area-inset-top)) 30rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.role-page__scene-host {
  position: relative;
  z-index: 1;
  transform-origin: right bottom;
  will-change: transform, opacity;
}

@keyframes role-page-scene-forward-a {
  0% {
    opacity: 0.84;
    transform: translate3d(44rpx, 24rpx, 0) scale(0.985);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes role-page-scene-forward-b {
  0% {
    opacity: 0.84;
    transform: translate3d(44rpx, 24rpx, 0) scale(0.985);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes role-page-scene-backward-a {
  0% {
    opacity: 0.84;
    transform: translate3d(-44rpx, 24rpx, 0) scale(0.985);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes role-page-scene-backward-b {
  0% {
    opacity: 0.84;
    transform: translate3d(-44rpx, 24rpx, 0) scale(0.985);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

.role-page__scene-host--forward.role-page__scene-host--tick-0 {
  animation: role-page-scene-forward-a 240ms cubic-bezier(0.25, 0.8, 0.25, 1);
}

.role-page__scene-host--forward.role-page__scene-host--tick-1 {
  animation: role-page-scene-forward-b 240ms cubic-bezier(0.25, 0.8, 0.25, 1);
}

.role-page__scene-host--backward.role-page__scene-host--tick-0 {
  animation: role-page-scene-backward-a 240ms cubic-bezier(0.25, 0.8, 0.25, 1);
}

.role-page__scene-host--backward.role-page__scene-host--tick-1 {
  animation: role-page-scene-backward-b 240ms cubic-bezier(0.25, 0.8, 0.25, 1);
}

.role-page__hero {
  padding: 30rpx;
}

.role-page__eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 0.14em;
  color: rgba(122, 74, 67, 0.68);
}

.role-page__title {
  display: block;
  margin-top: 12rpx;
  color: #7a4a43;
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.role-page__description {
  display: block;
  margin-top: 16rpx;
  color: rgba(122, 74, 67, 0.82);
  font-size: 26rpx;
  line-height: 1.7;
}

.role-page__section {
  margin-top: 20rpx;
}

.role-page__button + .role-page__button {
  margin-top: 16rpx;
}
