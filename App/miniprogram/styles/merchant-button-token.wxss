.merchant-button-token {
  --td-button-font-weight: 700;
  --td-button-border-radius: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(188, 113, 96, 0.16), inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.merchant-button-token--primary {
  --td-button-primary-color: #fffdfa;
  --td-button-primary-bg-color: #ff835f;
  --td-button-primary-border-color: rgba(255, 163, 126, 0.9);
  --td-button-primary-active-bg-color: #f66d4d;
  --td-button-primary-active-border-color: rgba(245, 116, 83, 0.94);
  --td-button-primary-disabled-color: rgba(255, 252, 250, 0.92);
  --td-button-primary-disabled-bg: rgba(225, 198, 191, 0.96);
  --td-button-primary-disabled-border-color: rgba(213, 186, 178, 0.96);
}

.merchant-button-token--outline {
  --td-bg-color-container: rgba(255, 248, 244, 0.98);
  --td-button-default-outline-color: #6f4f49;
  --td-button-default-outline-border-color: rgba(236, 178, 156, 0.92);
  --td-button-default-outline-active-bg-color: rgba(255, 238, 229, 0.98);
  --td-button-default-outline-active-border-color: rgba(228, 160, 135, 0.95);
  --td-button-default-outline-disabled-color: rgba(170, 150, 142, 0.92);
}

.merchant-button-token--danger {
  --td-bg-color-container: rgba(255, 244, 246, 0.98);
  --td-button-danger-outline-color: #9d3f4d;
  --td-button-danger-outline-border-color: rgba(209, 92, 104, 0.8);
  --td-button-danger-outline-active-bg-color: rgba(255, 232, 236, 0.98);
  --td-button-danger-outline-active-border-color: rgba(198, 83, 96, 0.92);
  --td-button-danger-outline-disabled-color: rgba(214, 171, 178, 0.92);
}
